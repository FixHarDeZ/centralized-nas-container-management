# Copy this file to .env and fill in real values (never commit .env to git!)
#
# This is the single source of truth for all stacks in the project.
# Edit here once, then run deploy.sh to upload to the NAS.

# ─── NAS Deployment (deploy.sh) ──────────────────────────────────────────────
NAS_USER=<NAS_USER>
NAS_HOST=<NAS_HOST>
NAS_PORT=2222
NAS_SSH_KEY=~/.ssh/id_ed25519
NAS_TARGET_PATH=/volume1/docker
# Used for `sudo docker compose` during stack restarts — SSH uses key auth only
NAS_SUDO_PASSWORD=your_sudo_password_here

# ─── Homepage — Basic Auth (Nginx reverse proxy) ─────────────────────────────
# Protects the Homepage UI with HTTP Basic Auth
# Hash is generated automatically at container start — no manual hashing needed
NGINX_BASIC_AUTH_USER=your_username
NGINX_BASIC_AUTH_PASS=your_password

# ─── Homepage — Allowed Hosts ─────────────────────────────────────────────────
# List every host used to access homepage, comma-separated
# e.g. bare DDNS (no port), DDNS:443, DDNS:3000, local IP:3000
HOMEPAGE_ALLOWED_HOSTS=<NAS_HOST>,<NAS_HOST>:443,<NAS_HOST>:3000,192.168.x.x:3000

# ─── Homepage — External URLs ─────────────────────────────────────────────────
HOMEPAGE_VAR_DDNS_BASE_HTTP=http://<NAS_HOST>
HOMEPAGE_VAR_DDNS_BASE_HTTPS=https://<NAS_HOST>
HOMEPAGE_VAR_QUICKCONNECT_URL=https://your-id.sg4.quickconnect.to

# ─── Homepage — NAS (DSM API) ─────────────────────────────────────────────────
# Use HTTP port 5000 (not HTTPS) to avoid SSL cert mismatch when using an IP
HOMEPAGE_VAR_NAS_URL=http://192.168.x.x:5000
HOMEPAGE_VAR_NAS_USERNAME=your_api_user          # dedicated DSM user without 2FA
HOMEPAGE_VAR_NAS_PASSWORD=your_api_user_password

# ─── Homepage — Jellyfin ──────────────────────────────────────────────────────
HOMEPAGE_VAR_JELLYFIN_URL=http://192.168.x.x:8096
HOMEPAGE_VAR_JELLYFIN_KEY=your_jellyfin_api_key

# ─── Homepage — Plex ──────────────────────────────────────────────────────────
HOMEPAGE_VAR_PLEX_URL=http://192.168.x.x:32400
HOMEPAGE_VAR_PLEX_KEY=your_plex_token

# ─── Homepage — Portainer ────────────────────────────────────────────────────
# Generate an API key in Portainer → Account Settings → Access Tokens
HOMEPAGE_VAR_PORTAINER_URL=http://192.168.x.x:9000
HOMEPAGE_VAR_PORTAINER_KEY=your_portainer_api_key

# ─── Homepage — Uptime Kuma ──────────────────────────────────────────────────
HOMEPAGE_VAR_UPTIME_KUMA_URL=http://192.168.x.x:3001
HOMEPAGE_VAR_UPTIME_KUMA_SLUG=your-status-page-slug

# ─── Homepage — Maid Tracker ─────────────────────────────────────────────────
HOMEPAGE_VAR_MAID_TRACKER_URL=http://192.168.x.x:5055

# ─── LINE Messaging API — Watchtower ─────────────────────────────────────────
# Found in LINE Developers Console → Messaging API settings (Watchtower channel)
WATCHTOWER_LINE_CHANNEL_ACCESS_TOKEN=your_watchtower_line_channel_access_token_here
# LINE user ID for personal push notifications (LINE Developers → Messaging API → Your user ID)
WATCHTOWER_LINE_USER_ID=your_line_user_id_here

# ─── LINE Messaging API — Maid Tracker ───────────────────────────────────────
# Found in LINE Developers Console → Messaging API settings (Maid Tracker channel)
MAID_LINE_CHANNEL_ACCESS_TOKEN=your_maid_tracker_line_channel_access_token_here
# LINE group ID for group notifications (starts with C)
MAID_LINE_GROUP_ID=your_line_group_id_here
# Channel secret for verifying webhook signatures
# (LINE Developers Console → Basic settings → Channel secret)
MAID_LINE_CHANNEL_SECRET=your_line_channel_secret_here

# ─── Maid Tracker — Optional ─────────────────────────────────────────────────
# Basic Auth to protect the web UI (if exposed to the internet)
# NGINX_BASIC_AUTH_USER and NGINX_BASIC_AUTH_PASS above are shared

# Time to send the monthly summary report (last day of month)
MONTHLY_REPORT_TIME=20:00

# ─── LINE Messaging API — Line Secretary ─────────────────────────────────────
# Create a new LINE OA channel at developers.line.biz → Messaging API
LINE_SECRETARY_CHANNEL_SECRET=your_line_secretary_channel_secret_here
LINE_SECRETARY_CHANNEL_ACCESS_TOKEN=your_line_secretary_channel_access_token_here
# Your LINE user ID (found in LINE Developers → Messaging API → Your user ID)
# Comma-separated if multiple users: Uxxxxxx,Uyyyyyy
LINE_SECRETARY_ALLOWED_USER_IDS=your_line_user_id_here

# ─── Line Secretary — AI Provider ────────────────────────────────────────────
# Choose provider: "groq" (free tier) or "openrouter" (pay-per-use, wider model selection)
AI_PROVIDER=groq

# Groq — free at console.groq.com (100K TPD for 70b, 500K TPD for 8b)
GROQ_API_KEY=your_groq_api_key_here

# OpenRouter — get key at openrouter.ai (supports Claude, GPT, Llama, etc.)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ─── Line Secretary — Notion ──────────────────────────────────────────────────
# Create an integration at notion.so/my-integrations → copy the Internal Integration Token
# Then share each page/database you want the bot to access with the integration
NOTION_TOKEN=your_notion_integration_token_here
