# ─── ROOT .env.example — deploy script + local scripts only ──────────────────
# Copy to .env and fill in real values. NEVER commit .env to git.
#
# This file is read by:
#   • scripts/deploy.sh   (NAS_* vars below)
#   • scripts/sync_notion.py  (NOTION_* vars below)
#
# Container secrets live in <stack>/.env.example → copy each to <stack>/.env.
# Containers on the NAS do NOT see this root file.

# ─── NAS Deployment (deploy.sh) ──────────────────────────────────────────────
NAS_USER=<NAS_USER>
NAS_HOST=<NAS_HOST>
NAS_PORT=2222
NAS_SSH_KEY=~/.ssh/id_ed25519
NAS_SSH_ALIAS=nas
NAS_TARGET_PATH=/volume2/docker
# Used for `sudo docker compose` during stack restarts — SSH uses key auth only
NAS_SUDO_PASSWORD=<NAS_SUDO_PASSWORD>

# ─── Local Scripts — Notion sync (scripts/sync_notion.py) ────────────────────
SYNC_NOTION_TOKEN=your_notion_integration_token_here
NOTION_SUMMARY_DATABASE_ID=your_notion_summary_database_id_here
