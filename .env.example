# คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าจริง (ห้าม commit .env ขึ้น git!)
#
# ไฟล์นี้คือ single source of truth สำหรับทุก stack ในโปรเจกต์
# แก้ไขที่นี่ที่เดียว แล้วรัน deploy.sh เพื่อ upload ขึ้น NAS

# ─── NAS Deployment (deploy.sh) ──────────────────────────────────────────────
NAS_USER=<NAS_USER>
NAS_HOST=<NAS_HOST>
NAS_PORT=2222
NAS_SSH_KEY=~/.ssh/id_ed25519
NAS_TARGET_PATH=/volume1/docker
# ใช้สำหรับ `sudo docker compose` ตอน restart stack — SSH ใช้ key auth เท่านั้น
NAS_SUDO_PASSWORD=your_sudo_password_here

# ─── Homepage — Basic Auth (Nginx reverse proxy) ─────────────────────────────
# ป้องกันหน้า Homepage ด้วย HTTP Basic Auth
# hash สร้างอัตโนมัติตอน container start — ไม่ต้อง hash เอง
NGINX_BASIC_AUTH_USER=your_username
NGINX_BASIC_AUTH_PASS=your_password

# ─── Homepage — Allowed Hosts ─────────────────────────────────────────────────
# ใส่ทุก host ที่ใช้เข้าถึง homepage คั่นด้วย comma
# เช่น bare DDNS (ไม่มี port), DDNS:443, DDNS:3000, local IP:3000
HOMEPAGE_ALLOWED_HOSTS=<NAS_HOST>,<NAS_HOST>:443,<NAS_HOST>:3000,192.168.x.x:3000

# ─── Homepage — External URLs ─────────────────────────────────────────────────
HOMEPAGE_VAR_DDNS_BASE_HTTP=http://<NAS_HOST>
HOMEPAGE_VAR_DDNS_BASE_HTTPS=https://<NAS_HOST>
HOMEPAGE_VAR_QUICKCONNECT_URL=https://your-id.sg4.quickconnect.to

# ─── Homepage — NAS (DSM API) ─────────────────────────────────────────────────
# ใช้ HTTP port 5000 (ไม่ใช่ HTTPS) เพื่อหลีกเลี่ยง SSL cert mismatch บน IP
HOMEPAGE_VAR_NAS_URL=http://192.168.x.x:5000
HOMEPAGE_VAR_NAS_USERNAME=your_nas_username    # same as NAS_USER
HOMEPAGE_VAR_NAS_PASSWORD=your_nas_password    # same as NAS_SUDO_PASSWORD

# ─── Homepage — Jellyfin ──────────────────────────────────────────────────────
HOMEPAGE_VAR_JELLYFIN_URL=http://192.168.x.x:8096
HOMEPAGE_VAR_JELLYFIN_KEY=your_jellyfin_api_key

# ─── Homepage — Plex ──────────────────────────────────────────────────────────
HOMEPAGE_VAR_PLEX_URL=http://192.168.x.x:32400
HOMEPAGE_VAR_PLEX_KEY=your_plex_token

# ─── Homepage — Portainer ────────────────────────────────────────────────────
# สร้าง API key ใน Portainer → Account Settings → Access Tokens
HOMEPAGE_VAR_PORTAINER_URL=http://192.168.x.x:9000
HOMEPAGE_VAR_PORTAINER_KEY=your_portainer_api_key

# ─── Homepage — Uptime Kuma ──────────────────────────────────────────────────
HOMEPAGE_VAR_UPTIME_KUMA_URL=http://192.168.x.x:3001
HOMEPAGE_VAR_UPTIME_KUMA_SLUG=your-status-page-slug

# ─── Homepage — Maid Tracker ─────────────────────────────────────────────────
HOMEPAGE_VAR_MAID_TRACKER_URL=http://192.168.x.x:5055

# ─── LINE Messaging API (Watchtower + Maid Tracker) ──────────────────────────
# หาได้ใน LINE Developers Console → Messaging API settings
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_here
# Watchtower: LINE user ID สำหรับ push notification ส่วนตัว
LINE_USER_ID=your_line_user_id_here
# Maid Tracker: group ID ของกลุ่ม LINE (ขึ้นต้นด้วย C)
LINE_GROUP_ID=your_line_group_id_here
# Maid Tracker: Channel secret สำหรับตรวจสอบ webhook signature
# (LINE Developers Console → Basic settings → Channel secret)
LINE_CHANNEL_SECRET=your_line_channel_secret_here

# ─── Maid Tracker — Optional ─────────────────────────────────────────────────
# Basic Auth สำหรับป้องกันหน้าเว็บ (ถ้า expose ออก internet)
# NGINX_BASIC_AUTH_USER ด้านบนใช้ร่วมกัน — ตั้งค่า password แยกด้านล่าง
BASIC_AUTH_PASSWORD=your_maid_tracker_password_here
# เวลาส่งรายงานสรุปรายเดือน (วันสุดท้ายของเดือน)
MONTHLY_REPORT_TIME=20:00
