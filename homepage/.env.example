# Homepage stack — Dashboard UI + Nginx auth proxy
# Copy to .env and fill in real values

# ─── Compose volume interpolation ────────────────────────────────────────────
NAS_VOLUME_ROOT=/volume2

# ─── Nginx Basic Auth (in front of homepage) ─────────────────────────────────
NGINX_BASIC_AUTH_USER=
NGINX_BASIC_AUTH_PASS=

# ─── Homepage app — allowed hosts (CSRF protection) ──────────────────────────
# Comma-separated list of every host:port used to access homepage
HOMEPAGE_ALLOWED_HOSTS=<NAS_HOST>,<NAS_HOST>:3000,<LAN_IP>:3000,<NAS_HOST>:443

# ─── Homepage — External URLs (used by config templates) ─────────────────────
HOMEPAGE_VAR_DDNS_BASE_HTTP=http://<NAS_HOST>
HOMEPAGE_VAR_DDNS_BASE_HTTPS=https://<NAS_HOST>
HOMEPAGE_VAR_QUICKCONNECT_URL=https://<QUICKCONNECT_ID>.<REGION>.quickconnect.to

# ─── Homepage — Synology DSM API (Download Station + diskstation widget) ─────
# Use HTTP port 5000 (not HTTPS) to avoid SSL cert mismatch when using an IP
HOMEPAGE_VAR_NAS_URL=http://<LAN_IP>:5000
HOMEPAGE_VAR_NAS_USERNAME=
HOMEPAGE_VAR_NAS_PASSWORD=

# ─── Homepage — Jellyfin widget ──────────────────────────────────────────────
HOMEPAGE_VAR_JELLYFIN_URL=http://<LAN_IP>:8096
HOMEPAGE_VAR_JELLYFIN_KEY=

# ─── Homepage — Plex widget ──────────────────────────────────────────────────
HOMEPAGE_VAR_PLEX_URL=http://<LAN_IP>:32400
HOMEPAGE_VAR_PLEX_KEY=

# ─── Homepage — Portainer widget ─────────────────────────────────────────────
# Generate API key in Portainer → Account Settings → Access Tokens
HOMEPAGE_VAR_PORTAINER_URL=http://<LAN_IP>:9000
HOMEPAGE_VAR_PORTAINER_KEY=

# ─── Homepage — Uptime Kuma widget ───────────────────────────────────────────
HOMEPAGE_VAR_UPTIME_KUMA_URL=http://<LAN_IP>:3001
HOMEPAGE_VAR_UPTIME_KUMA_SLUG=nas-status

# ─── Homepage — Maid Tracker link ────────────────────────────────────────────
HOMEPAGE_VAR_MAID_TRACKER_URL=https://<NAS_HOST>:5056

# ─── Homepage — TorrentWatch widget ──────────────────────────────────────────
HOMEPAGE_VAR_TORRENTWATCH_URL=http://<LAN_IP>:5059
