# คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าจริง (ห้าม commit .env ขึ้น git!)

# ─── NAS Credentials ─────────────────────────────────────────────────────────
NAS_USERNAME=your_nas_username
NAS_PASSWORD=your_nas_password
NAS_LOCAL_URL=https://192.168.x.x:5001

# ─── Media API Keys ───────────────────────────────────────────────────────────
JELLYFIN_URL=http://192.168.x.x:8096
JELLYFIN_KEY=your_jellyfin_api_key

PLEX_URL=http://192.168.x.x:32400
PLEX_KEY=your_plex_token

# ─── Portainer ────────────────────────────────────────────────────────────────
PORTAINER_URL=http://192.168.x.x:9000
PORTAINER_KEY=your_portainer_api_key

# ─── Uptime Kuma ─────────────────────────────────────────────────────────────
UPTIME_KUMA_URL=http://192.168.x.x:3001
UPTIME_KUMA_SLUG=your-slug

# ─── Maid Tracker ────────────────────────────────────────────────────────────
MAID_TRACKER_URL=http://192.168.x.x:5055

# ─── External URLs ────────────────────────────────────────────────────────────
EXTERNAL_BASE=http://your-ddns.synology.me
QUICKCONNECT_URL=https://your-id.sg4.quickconnect.to
# ใส่ทุก host ที่ใช้เข้าถึง homepage คั่นด้วย comma
# เช่น DDNS, local IP, หรือ public IP
HOMEPAGE_ALLOWED_HOSTS=your-ddns.synology.me:3000,192.168.x.x:3000
