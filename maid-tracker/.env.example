# คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าจริง (ห้าม commit .env ขึ้น git!)
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_here
LINE_GROUP_ID=your_line_group_id_here
# LINE_CHANNEL_SECRET ใช้สำหรับตรวจสอบ webhook signature จาก LINE (หาได้ใน LINE Developers Console → Channel basic settings)
LINE_CHANNEL_SECRET=your_line_channel_secret_here

# HTTP Basic Auth สำหรับป้องกันหน้าเว็บ (ไม่บังคับ — ถ้าไม่ตั้งค่าระบบเปิดให้ทุกคนในเครือข่าย)
# แนะนำให้ตั้งถ้า expose port ออก internet (เพื่อรับ LINE webhook)
BASIC_AUTH_USER=admin
BASIC_AUTH_PASSWORD=your_password_here

# เวลาส่งรายงานสรุปรายเดือน (วันสุดท้ายของเดือน) — ค่าเริ่มต้น 20:00
MONTHLY_REPORT_TIME=20:00
