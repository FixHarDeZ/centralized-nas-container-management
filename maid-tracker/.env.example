# Maid Tracker stack — Time tracking + payroll
# Copy to .env and fill in real values

# ─── LINE Messaging API (Maid Tracker channel) ───────────────────────────────
MAID_LINE_CHANNEL_ACCESS_TOKEN=
MAID_LINE_CHANNEL_SECRET=
# LINE group ID for monthly reports (starts with C)
MAID_LINE_GROUP_ID=

# ─── Nginx Basic Auth (protects web UI when exposed) ─────────────────────────
NGINX_BASIC_AUTH_USER=
NGINX_BASIC_AUTH_PASS=

# ─── Scheduling ──────────────────────────────────────────────────────────────
# Time to send the monthly summary report (last day of month, 24h format)
MONTHLY_REPORT_TIME=20:00
