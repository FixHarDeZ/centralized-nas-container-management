# TorrentWatch stack — Scraper + LINE/Telegram notifier
# Copy to .env and fill in real values

# ─── Compose volume interpolation ────────────────────────────────────────────
# Host path where .torrent files are saved (Synology watch folder)
NAS_TORRENT_PATH=/var/services/homes/<NAS_USER>/Torrents_Watch

# ─── Site credentials (bearbit.org) ──────────────────────────────────────────
TORRENTWATCH_SITE_USERNAME=
TORRENTWATCH_SITE_PASSWORD=
# Comma-separated initial listing URLs (seeded on first start)
TORRENTWATCH_DEFAULT_URLS=https://bearbit.org/viewbrsb.php

# ─── Nginx Basic Auth (protects web UI when exposed) ─────────────────────────
NGINX_BASIC_AUTH_USER=
NGINX_BASIC_AUTH_PASS=

# ─── LINE Messaging API (TorrentWatch channel) ───────────────────────────────
TORRENTWATCH_LINE_ACCESS_TOKEN=
TORRENTWATCH_LINE_USER_ID=

# ─── Telegram Bot API ────────────────────────────────────────────────────────
# Bot Token from @BotFather on Telegram
TORRENTWATCH_TELEGRAM_BOT_TOKEN=
# Your chat ID — find via Settings page "ค้นหา Chat ID" or @userinfobot
TORRENTWATCH_TELEGRAM_CHAT_ID=
