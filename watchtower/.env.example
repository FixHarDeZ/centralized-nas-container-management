# Watchtower stack — Auto container updates + LINE notifier sidecar
# Copy to .env and fill in real values

# ─── LINE Messaging API (Watchtower channel) ─────────────────────────────────
WATCHTOWER_LINE_CHANNEL_ACCESS_TOKEN=
# LINE user ID for push notifications
WATCHTOWER_LINE_USER_ID=

# ─── Telegram Bot API (optional — leave blank to disable) ────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
